# Robomesh Docker Compose Environment
# Copy to .env and fill in secrets before running docker-compose up.

# --- Required Secrets ---
# IMPORTANT: For distributed deployment, set this to the Database Machine's
# LAN IP (e.g., 192.168.1.100). "localhost" only works when Postgres runs
# on the same machine or in docker-compose.dev.yml (local dev).
POSTGRES_HOST=
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
JWT_SECRET=changeme_generate_a_long_random_string

# --- Optional Overrides ---
# POSTGRES_USER=robomesh
# POSTGRES_DB=robomesh_db
# POSTGRES_PORT=5432
# DEBUG=true
# HTTP_PORT=8080
# TCP_PORT=5000
# MQTT_PORT=1883
# FRONTEND_PORT=3000
# HANDLERS_BASE_PATH=./handlers
