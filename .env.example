# Robomesh Environment Overrides
# ================================
# Copy to .env and fill in secrets before running docker compose.
#
# Default ports and settings are defined in defaults.env (loaded automatically).
# Only set values here that you want to OVERRIDE from the defaults, plus secrets.

# --- Required Secrets ---
# IMPORTANT: For distributed deployment, set POSTGRES_HOST to the Database
# Machine's LAN IP (e.g., 192.168.1.100). "localhost" only works when Postgres
# runs on the same machine or in docker-compose.dev.yml (local dev).
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
JWT_SECRET=changeme_generate_a_long_random_string

# --- Optional: Override defaults from defaults.env ---
# Uncomment and change any value you want to override.
# See defaults.env for the full list of configurable settings.
#
# POSTGRES_HOST=192.168.1.100
# HTTP_PORT=8080
# TCP_PORT=5002
# UDP_PORT=5001
# MQTT_PORT=1883
# TERMINAL_PORT=6000
# FRONTEND_PORT=3000
# DEBUG=true
# HANDLERS_BASE_PATH=./handlers
