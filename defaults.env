# Robomesh Default Configuration
# ================================
# Single source of truth for all default ports and settings.
# Docker Compose loads this automatically via env_file.
#
# To override any value:
#   1. Set it in your .env file (for Docker Compose)
#   2. Export it as an environment variable (for direct execution)
#
# Changing a port here propagates to all Docker services, tests, and scripts.
# For non-Docker usage, config.yaml values apply unless overridden by env vars.

# --- Server Ports ---
HTTP_PORT=8080
TCP_PORT=5002
UDP_PORT=5001
MQTT_PORT=1883
TERMINAL_PORT=6000

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=robomesh
POSTGRES_DB=robomesh_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Frontend ---
FRONTEND_PORT=3000
PUBLIC_BACKEND_PORT=8080
